# ─── NeuroLex Backend Environment ───────────────────────────────────────────
# Copy this file to ".env" and fill in real values. NEVER commit your .env file.

# OpenRouter LLM provider — get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENROUTER_MODEL=openai/gpt-oss-120b:free

# MongoDB Atlas connection string (SRV format)
# Create a free cluster at https://www.mongodb.com/atlas and a database named "NeuroLex"
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/NeuroLex?retryWrites=true&w=majority
MONGO_DB_NAME=NeuroLex

# Django
DJANGO_SECRET_KEY=generate-a-long-random-secret-key
DEBUG=True
